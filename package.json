{
  "name": "bun-test-cloudflare",
  "version": "0.0.7",
  "type": "module",
  "description": "Run Cloudflare Workers tests in Bun",
  "sideEffects": false,
  "scripts": {
    "prepublishOnly": "bun run check:fix && bun run test",
    "test": "bun test",
    "check": "tsc --noEmit --project tsconfig.json && npx @biomejs/biome check .",
    "check:fix": "tsc --noEmit --project tsconfig.json && npx @biomejs/biome check --write ."
  },
  "exports": {
    ".": {
      "types": "./src/harness.ts",
      "default": "./src/harness.ts"
    },
    "./setup": {
      "types": "./src/setup.ts",
      "default": "./src/setup.ts"
    }
  },
  "files": [
    "src/"
  ],
  "keywords": [
    "bun",
    "cloudflare",
    "cloudflare-workers",
    "testing",
    "wrangler"
  ],
  "author": "James Waterhouse <09jwater@gmail.com>",
  "license": "MIT",
  "repository": "https://github.com/Censkh/bun-test-cloudflare",
  "dependencies": {
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "typescript": "7.0.2",
    "wrangler": "4.110.0"
  },
  "peerDependencies": {
    "wrangler": ">=4.104.0"
  }
}
